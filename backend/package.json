{
  "name": "outvier-backend",
  "version": "1.0.0",
  "description": "Outvier Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/jobs/workerProcess.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/jobs/workerProcess.js",
