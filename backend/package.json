    "cricos:sync-all": "ts-node src/scripts/syncCricosAll.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.44",
    "@langchain/groq": "^1.2.0",
    "@langchain/ollama": "^1.2.7",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "crawlee": "^3.16.0",
    "crypto-js": "^4.2.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.3.4",
    "mongoose": "^8.3.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "p-limit": "^5.0.0",
    "playwright": "^1.59.1",
    "slugify": "^1.6.6",
    "zod": "^3.23.8"
