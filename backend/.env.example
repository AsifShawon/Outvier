# Backend Environment Variables
# Copy this file to .env and fill in the values

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/outvier

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# ── CORS ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Redis (BullMQ background jobs — Phase 2) ───────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Encryption (for AI provider API keys stored in DB) ─────────────────────
# Must be exactly 32 characters
ENCRYPTION_SECRET=change_me_to_32_char_random_string_!

# ── AI Providers (Phase 5) ─────────────────────────────────────────────────
# These are fallback env vars. Admins can also set keys via /admin/settings/ai
DEFAULT_AI_PROVIDER=groq

GROQ_API_KEY=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
MISTRAL_API_KEY=

# ── Power BI (optional — Phase 4) ─────────────────────────────────────────
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=
POWERBI_DATASET_ID=
